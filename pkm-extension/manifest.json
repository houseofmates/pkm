{
    "manifest_version": 2,
    "name": "pkm capture",
    "short_name": "capture",
    "version": "1.2",
    "description": "capture content to your pkm brain",
    "permissions": [
        "contextMenus",
        "storage",
        "activeTab",
        "http://*/*",
        "https://*/*"
    ],
    "browser_action": {
        "default_icon": {
            "48": "icon-48.png"
        },
        "default_title": "pkm capture settings",
        "default_popup": "popup.html"
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "pkm-capture@houseofmates.space",
            "strict_min_version": "42.0"
        }
    }
}