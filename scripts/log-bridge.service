[Unit]
Description=Minecraft Log Bridge
After=network.target

[Service]
ExecStart=/home/house/.nvm/versions/node/v24.12.0/bin/node /home/house/pkm/scripts/log-bridge.js
WorkingDirectory=/home/house/pkm
Restart=always
User=house
Environment=PATH=/usr/bin:/usr/local/bin

[Install]
WantedBy=multi-user.target
