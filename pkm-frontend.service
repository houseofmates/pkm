[Unit]
Description=PKM Frontend Dev Server (with Hot Reload)
After=network.target

[Service]
ExecStart=/home/house/.nvm/versions/node/v24.12.0/bin/node /home/house/pkm/node_modules/.bin/vite dev --port 3010 --host 0.0.0.0 --strictPort
WorkingDirectory=/home/house/pkm
Restart=always
User=house
Environment=PATH=/home/house/.nvm/versions/node/v24.12.0/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
