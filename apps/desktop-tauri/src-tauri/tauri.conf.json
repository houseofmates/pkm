{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "pkm",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:3010",
    "beforeDevCommand": "npm run dev --workspace=@pkm/core",
    "beforeBuildCommand": "npm run build --workspace=@pkm/core"
  },
  "app": {
    "windows": [
      {
        "title": "pkm",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}