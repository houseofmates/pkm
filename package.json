{
  "name": "pkm-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "predev": "node scripts/utils/setup-env.cjs",
    "prebuild": "node scripts/utils/setup-env.cjs",
    "dev": "concurrently -k \"npm run dev --workspace=pkm-web\" \"npm run backend\"",
    "dev:dupe": "concurrently -k \"npm run dev --workspace=pkm-web -- --port 3010\" \"npm run backend\"",
    "build": "npm run build --workspace=pkm-web",
    "test": "npm run test --workspace=pkm-web",
    "test:e2e": "node scripts/e2e/canvas-ai.cjs",
    "lint": "eslint .",
    "lowercase:check": "node scripts/lowercase-comments.cjs",
    "lowercase:fix": "node scripts/lowercase-comments.cjs --apply",
    "check:ui-lowercase": "node scripts/check-ui-lowercase.cjs",
    "check:ui-lowercase:fix": "node scripts/check-ui-lowercase.cjs --apply",
    "check:ui-lowercase:lenient": "node scripts/check-ui-lowercase.cjs --staged || true",
    "lowercase:staged": "node scripts/lowercase-comments.cjs --staged && npm run check:ui-lowercase:lenient",
    "lowercase:staged:fix": "node scripts/lowercase-comments.cjs --staged --apply && node scripts/check-ui-lowercase.cjs --staged --apply",
    "lowercase:all": "npm run lowercase:check && npm run check:ui-lowercase",
    "precommit": "npx lint-staged",
    "preview": "vite preview",
    "serve:prod": "concurrently -k \"npm run backend\" \"npm run preview\"",
    "backend": "PORT=4100 node packages/backend/server.js",
    "electron:dev": "npm run electron:dev --workspace=pkm-desktop-electron",
    "electron:build": "npm run build --workspace=pkm-desktop-electron",
    "tauri": "npm run tauri --workspace=pkm-desktop-tauri",
    "tauri:dev": "npm run tauri:dev --workspace=pkm-desktop-tauri",
    "tauri:build": "npm run tauri:build --workspace=pkm-desktop-tauri",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "sync:daemon": "node scripts/auto-git-sync.js",
    "schema:completions": "ts-node scripts/schema-completions.ts",
    "sync:install-service": "sudo scripts/install-auto-git-sync.sh",
    "build:android": "npm run build --workspace=pkm-web && npx cap sync android",
    "notion:import": "node scripts/notion-import.js",
    "test:notion": "vitest src/features/notion-import/__tests__"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^6.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-color": "^3.17.1",
    "@tiptap/extension-image": "^3.16.0",
    "@tiptap/extension-mention": "^3.16.0",
    "@tiptap/extension-placeholder": "^3.16.0",
    "@tiptap/extension-text-style": "^3.17.1",
    "@tiptap/extension-typography": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "@tiptap/suggestion": "^3.16.0",
    "@types/lodash": "^4.17.21",
    "@types/react-grid-layout": "^1.3.6",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "comlink": "^4.4.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "discord.js": "^13.17.1",
    "express": "^5.2.1",
    "fabric": "^7.0.0-rc1",
    "framer-motion": "^12.25.0",
    "idb": "^7.1.1",
    "jspdf": "^4.2.0",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "lucide-react": "^0.562.0",
    "lz-string": "^1.5.0",
    "multer": "^2.0.2",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^4.0.379",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-force-graph-2d": "^1.29.0",
    "react-grid-layout": "^2.1.1",
    "react-hook-form": "^7.69.0",
    "react-intersection-observer": "^10.0.2",
    "react-is": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable": "^3.0.5",
    "react-router-dom": "^7.11.0",
    "react-use": "^17.6.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "recharts": "^3.6.0",
    "rehype-raw": "^7.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tippy.js": "^6.3.7",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "husky": "^8.0.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "nock": "^14.0.11",
    "postcss": "^8.5.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  },
  "prepare": "husky install",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs}": [
      "eslint --fix",
      "git add"
    ]
  },
  "build": {
    "appId": "com.houseofmates.pkm",
    "productName": "pkm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
