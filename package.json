    "react-use": "^17.6.0",
    "recharts": "^3.6.0",
    "rehype-raw": "^7.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
