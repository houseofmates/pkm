    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "discord.js": "^14.25.1",
    "express": "^5.2.1",
    "fabric": "^7.0.0-rc1",
    "framer-motion": "^12.25.0",
    "jspdf": "^2.5.1",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "lucide-react": "^0.562.0",
    "lz-string": "^1.5.0",
    "multer": "^2.0.2",
