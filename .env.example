# PKM master .env example - fill these locally, never commit real secrets.

# Discord bot
DISCORD_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN

# Backend broadcast auth (used by n8n/workflows to call /api/broadcast)
BROADCAST_AUTH_KEY=REPLACE_WITH_BROADCAST_AUTH_KEY

# NocoBase / API
NOCOBASE_API_KEY=REPLACE_WITH_NOCOBASE_API_KEY
VITE_NOCOBASE_API_TOKEN=REPLACE_WITH_VITE_NOCOBASE_API_TOKEN
PUBLIC_ACCESS_TOKEN=REPLACE_WITH_PUBLIC_ACCESS_TOKEN

# Admin / service keys
ADMIN_API_KEY=REPLACE_WITH_ADMIN_API_KEY
API_TOKEN=REPLACE_WITH_API_TOKEN

# External integrations
VIRUSTOTAL_API_KEY=REPLACE_WITH_VIRUSTOTAL_API_KEY
IMMICH_API_KEY=REPLACE_WITH_IMMICH_API_KEY
DEEPAI_API_KEY=REPLACE_WITH_DEEPAI_API_KEY
HORDE_API_KEY=REPLACE_WITH_HORDE_API_KEY
HF_TOKEN=REPLACE_WITH_HF_TOKEN

# Telegram
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN

# Nextcloud/HTTP basic (if used by workflows)
NEXTCLOUD_HTTP_USER=REPLACE_WITH_NEXTCLOUD_USER
NEXTCLOUD_HTTP_PASS=REPLACE_WITH_NEXTCLOUD_PASS

# Database
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
DATABASE_URL=postgres://user:REPLACE_WITH_DB_PASSWORD@host:5432/dbname

# Android keys (if applicable)
KEYSTORE_PASSWORD=REPLACE_WITH_KEYSTORE_PASSWORD
KEY_PASSWORD=REPLACE_WITH_KEY_PASSWORD

# Other
HOUSEOFMATES_DOMAIN=houseofmates.space
VITE_API_URL=https://db.houseofmates.space/api
VITE_BASE_URL=https://pkm.houseofmates.space
VITE_API_URL=https://db.houseofmates.space/api
VITE_SOCKET_URL=wss://pkm.houseofmates.space
# NOCOBASE_TOKEN=REPLACE_WITH_YOUR_NOCOBASE_TOKEN
# DISCORD_TOKEN=REPLACE_WITH_YOUR_DISCORD_BOT_TOKEN

# Copy this file to `.env` and fill in secrets. Do NOT commit `.env` with real secrets.
# PKM Environment Configuration
# Copy this file to .env.local and fill in your values
# The setup script will automatically use .env.local if it exists

# ============================================
# Backend Configuration
# ============================================

# Server port
HOUSEOFMATES_DOMAIN=yourdomain.com
BLOG_DOMAIN=blog.yourdomain.com
HOME_DOMAIN=home.yourdomain.com
DUPE_DOMAIN=dupe.yourdomain.com
API_DOMAIN=api.yourdomain.com
ADMIN_API_KEY=your-admin-api-key
DISCORD_TOKEN=your-discord-token
NOCOBASE_API_KEY=your-nocobase-api-key
PKM_LLM_KEY=your-llm-key
GITHUB_TOKEN=your-github-token
BROADCAST_AUTH_KEY=your-broadcast-auth-key
KEYSTORE_PASSWORD=your-keystore-password
KEY_PASSWORD=your-key-password
POSTGRES_PASSWORD=your-postgres-password
DB_PASSWORD=your-db-password
DB_POSTGRESDB_PASSWORD=your-db-postgres-password
VITE_NOCOBASE_API_TOKEN=your-nocobase-api-token
VITE_DOMAIN=yourdomain.com
EMAIL=admin@yourdomain.com
NGINX_CONF=/etc/nginx/sites-available/yourdomain.com
ALLOWED_ORIGINS=http://localhost:3011,https://yourdomain.com
API_BASE=https://db.yourdomain.com/api
API_TOKEN=your-api-token
# ============================================

# Maximum file upload size (bytes)
# MAX_FILE_SIZE=10485760

# CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3011,https://yourdomain.com
