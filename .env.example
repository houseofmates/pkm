# PKM Environment Configuration
# Copy this file to .env.local and fill in your values
# The setup script will automatically use .env.local if it exists

# ============================================
# Backend Configuration
# ============================================

# Server port
PORT=4100

# Authentication key for webhooks and integrations
# Generate a secure random key for production
BROADCAST_AUTH_KEY=your-secret-key-here

# ============================================
# Frontend Configuration
# ============================================

# API URL - where the backend is running
# For local development: http://localhost:4100/api
# For production: https://your-domain.com/api
VITE_API_URL=http://localhost:4100/api

# Public URL - for sharing documents publicly
# For local development: http://localhost:3011
# For production: https://your-domain.com
VITE_PUBLIC_URL=http://localhost:3011

# NocoBase Configuration (optional)
# If you're using NocoBase as a backend database
VITE_NOCOBASE_URL=https://your-nocobase-instance.com
VITE_NOCOBASE_API_TOKEN=your-nocobase-api-token-here

# Primary domain for routing logic
# Used for subdomain detection and public/private routing
VITE_DOMAIN=localhost

# ============================================
# Optional Configuration
# ============================================

# Maximum file upload size (bytes)
# MAX_FILE_SIZE=10485760

# CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3011,https://yourdomain.com

# Ollama API URL for Wilson AI
VITE_OLLAMA_API_URL=http://localhost:11434/api/generate

# Public Access Token for guest users
VITE_PUBLIC_ACCESS_TOKEN=your-guest-token-here
