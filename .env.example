# PKM Environment Configuration

# Backend Server
PORT=4100

# Authentication & Security
# Generate a secure random key for production use
BROADCAST_AUTH_KEY=your-secret-key-here

# Optional: Database connection (if using external DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/pkm

# Optional: File upload limits
# MAX_FILE_SIZE=10485760

# Optional: CORS origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3011,https://yourdomain.com
