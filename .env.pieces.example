# pieces os mcp configuration
# copy to .env and adjust as needed

# pieces os mcp server url (default: http://192.168.4.250:39301/model_context_protocol/2025-03-26/mcp)
PIECES_MCP_URL=http://192.168.4.250:39301/model_context_protocol/2025-03-26/mcp

# how many hours of recent activity to fetch from pieces (default: 2)
PIECES_CONTEXT_HOURS=2

# bot memory directory (default: ./data/bot-memory)
# PKM_BOT_MEMORY_DIR=./data/bot-memory
