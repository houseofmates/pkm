#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

npx lint-staged

# build all releases (appimage, deb, exe, apk)
# to skip: git commit --no-verify -m "your message"
# The script can be heavy and may fail on machines lacking electron-builder
# or android SDK; we don't want to block commits, so just warn on error.
echo "building all releases..."
npm run build:all || echo "release build failed, continuing commit"

# stage only version.json locally; the CI workflow will commit the binaries
# this prevents large AppImage/deb files being accidentally included in commits
git add releases/version.json || true
